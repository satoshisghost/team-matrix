# ===== REQUIRED =====
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/teammatrix
JWT_SECRET=your-super-secret-key-change-me

# ===== SERVER =====
PORT=5000
NODE_ENV=production
BASE_URL=https://your-app.up.railway.app
SESSION_SECRET=your-session-secret-change-me

# ===== GOOGLE OAUTH =====
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://your-app.up.railway.app/api/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== APPLE SIGN IN =====
# Get from: developer.apple.com → Certificates, Identifiers & Profiles → Services
# Registered redirect URI: https://your-app.up.railway.app/api/oauth/apple/callback
APPLE_CLIENT_ID=com.yourcompany.teammatrix
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
# Paste the full contents of your .p8 key — replace newlines with \n
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGH...\n-----END PRIVATE KEY-----

# ===== EMAIL (optional — for playbook distribution) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
